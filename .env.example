# App
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=10000

# Database (Supabase/Postgres system of record)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Search engine selector: supabase | meilisearch
SEARCH_ENGINE=supabase

# CORS
# Comma-separated list of explicit origins allowed by FastAPI CORS middleware
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://probuy-frontend.onrender.com
# Optional regex for preview/staging domains
CORS_ALLOW_ORIGIN_REGEX=^http://(localhost|127\\.0\\.0\\.1)(:\\d+)?$|^https://.*\\.onrender\\.com$|^https://.*\\.vercel\\.app$

# Meilisearch (optional / phase 2)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=products
MEILISEARCH_TIMEOUT_SECONDS=2.0
